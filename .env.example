# ---- Frontend (Vite). Se exponen al navegador: NUNCA pongas secretos aqui. ----
# URL del proyecto Supabase y clave anon (publica). Requeridas si VITE_AUTH_MODE=supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# "demo" = datos locales (localStorage), sin backend. "supabase" = login real + datos en Supabase.
VITE_AUTH_MODE=demo

# Pausa (ms) entre items en el procesamiento DEMO del navegador.
VITE_PROCESSING_PAUSE_MS=1500

# ---- Worker / Edge Function (NO se exponen al navegador). ----
# Estas se configuran como secrets de la Edge Function, no en el .env del frontend:
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=... PROCESSING_PAUSE_MS=1500 ...
# SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY las inyecta Supabase automaticamente en las functions.
#   PROCESSING_PAUSE_MS      Pausa (ms) entre consultas reales a Aduanas. Default 1500.
#   ADUANAS_FORM_URL         URL del formulario inicial para leer pageCode. Validar en produccion.
#   ADUANAS_TIMEOUT_MS       Timeout por request a Aduanas. Default 20000.
#   MAX_ITEMS_POR_INVOCACION Items por invocacion del worker (limite de tiempo). Default 100.
